{
    "buildCommand": "./build_vercel.sh",
    "outputDirectory": "public",
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/pricelist/:branch",
            "destination": "/pricelist.html?branch=:branch"
        },
        {
            "source": "/((?!api/|pricelist\\.html|pricelist\\.js).*)",
            "destination": "/index.html"
        }
    ]
}