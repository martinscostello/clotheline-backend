{
    "buildCommand": "./build_vercel.sh",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/pricelist/(.*)",
            "destination": "/pricelist-app.html?branch=$1"
        },
        {
            "source": "/((?!api/|pricelist|pricelist-app\\.html|pricelist\\.js).*)",
            "destination": "/index.html"
        }
    ]
}